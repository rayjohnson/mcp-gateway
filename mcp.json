{
  "$schema": "https://docs.1mcp.app/schemas/v1.0.0/mcp-config.json",
  "version": "1.0.0",
  "serverDefaults": {
    "connectionTimeout": 10000,
    "requestTimeout": 30000,
    "inheritParentEnv": true
  },
  "mcpServers": {
    "imessage": {
      "command": "uvx",
      "args": [
        "--from", "fastmcp==0.4.1",
        "--with", "imessagedb",
        "--with", "phonenumbers",
        "fastmcp", "run",
        "${IMESSAGE_SCRIPT_PATH}"
      ],
      "tags": ["communication", "macos"]
    },
    "obsidian": {
      "command": "uvx",
      "args": ["mcp-obsidian"],
      "env": {
        "OBSIDIAN_API_KEY": "${OBSIDIAN_API_KEY}",
        "OBSIDIAN_HOST": "${OBSIDIAN_HOST}",
        "OBSIDIAN_PORT": "${OBSIDIAN_PORT}"
      },
      "tags": ["knowledge", "notes"]
    },
    "things3": {
      "command": "npx",
      "args": ["-y", "things3-mcp@latest"],
      "env": {
        "THINGS3_AUTH_TOKEN": "${THINGS3_AUTH_TOKEN}"
      },
      "tags": ["productivity", "tasks", "macos"]
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://gmailmcp.googleapis.com/mcp/v1"],
      "tags": ["communication", "email"]
    },
    "google-calendar": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://calendarmcp.googleapis.com/mcp/v1"],
      "tags": ["communication", "calendar", "google"]
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://drivemcp.googleapis.com/mcp/v1"],
      "tags": ["storage", "files", "google"]
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.slack.com/mcp"],
      "tags": ["communication", "work"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      },
      "tags": ["development", "git"]
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "linear-mcp-server"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      },
      "tags": ["development", "project-management"]
    },
    "notion": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"],
      "tags": ["knowledge", "project-management"]
    },
    "honeycomb": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.honeycomb.io/mcp"],
      "tags": ["observability", "development"]
    },
    "home-assistant": {
      "command": "uvx",
      "args": ["ha-mcp@latest"],
      "env": {
        "HOMEASSISTANT_URL": "${HOMEASSISTANT_URL}",
        "HOMEASSISTANT_TOKEN": "${HOMEASSISTANT_TOKEN}"
      },
      "tags": ["home", "automation", "macos"]
    },
    "1password": {
      "command": "npx",
      "args": ["-y", "@jrejaud/op-mcp"],
      "env": {},
      "tags": ["security", "passwords"]
    }
  }
}
