# ─────────────────────────────────────────────
# MCP Gateway – Environment Variables
# Copy to .env and fill in values before starting.
# Secrets should be sourced from 1Password via 1password-export.sh
# ─────────────────────────────────────────────

# iMessage
# Default: ~/Library/Messages/chat.db — only set if using a custom path.
# Requires Full Disk Access for the process in System Settings > Privacy & Security.
IMESSAGE_DB=~/Library/Messages/chat.db

# Obsidian
# Absolute path to your Obsidian vault directory.
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian/MyVault

# Things 3
# From Things 3 → Settings → General → Enable Things URLs → Manage (copy token).
THINGS3_AUTH_TOKEN=

# Gmail
# File-based OAuth — no token here. Run the one-time auth setup first:
#   npx @gongrzhe/server-gmail-autoauth-mcp auth
# That saves credentials to ~/.gmail-mcp/credentials.json automatically.
# You DO need ~/.gmail-mcp/gcp-oauth.keys.json (downloaded from Google Cloud Console).

# Slack
# Bot User OAuth Token (starts with xoxb-).
# Create a Slack app at api.slack.com/apps, add OAuth scopes, install to workspace.
SLACK_BOT_TOKEN=xoxb-
# Workspace ID (starts with T). Found in Slack → Settings → About.
SLACK_TEAM_ID=T

# GitHub
# Personal Access Token. Create at github.com/settings/tokens.
# Required scopes: repo, read:org (add more as needed).
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_

# Linear
# Personal API key. Create at linear.app → Settings → API → Personal API keys.
LINEAR_API_KEY=lin_api_

# Notion
# Integration token. Create at notion.so/profile/integrations → New integration.
# Share pages/databases with the integration inside Notion.
NOTION_TOKEN=ntn_
