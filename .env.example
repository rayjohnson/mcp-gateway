# ─────────────────────────────────────────────
# MCP Gateway – Environment Variables
# Copy to .env and fill in values before starting.
# Run ./1password-export.sh to auto-populate from 1Password where possible.
# ─────────────────────────────────────────────

# iMessage
# Path to the custom fastmcp iMessage server script.
IMESSAGE_SCRIPT_PATH=/Users/ray.johnson/src/imessage-query-fastmcp-mcp-server/imessage-query-server.py

# Obsidian (via Local REST API plugin — Obsidian must be running with plugin enabled)
# Plugin: https://github.com/coddingtonbear/obsidian-local-rest-api
OBSIDIAN_API_KEY=
OBSIDIAN_HOST=localhost
OBSIDIAN_PORT=27123

# Things 3
# From Things 3 → Settings → General → Enable Things URLs → Manage (copy token).
THINGS3_AUTH_TOKEN=

# Gmail — file-based OAuth, no token here.
# One-time setup: npx @gongrzhe/server-gmail-autoauth-mcp auth
# Requires ~/.gmail-mcp/gcp-oauth.keys.json from Google Cloud Console.

# Google Calendar + Drive — OAuth prompt on first connect (no token needed here).

# Slack
# Bot User OAuth Token (starts with xoxb-).
# Create at api.slack.com/apps → OAuth & Permissions → install to workspace.
SLACK_BOT_TOKEN=xoxb-
# Workspace ID (starts with T). Slack → Settings → About this workspace.
SLACK_TEAM_ID=T

# GitHub
# Personal Access Token. Create at github.com/settings/tokens.
# Scopes needed: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_

# Linear
LINEAR_API_KEY=

# Notion
# Integration token from notion.so/profile/integrations.
# Remember to share pages/databases with the integration inside Notion.
NOTION_TOKEN=ntn_

# Honeycomb — OAuth prompt on first connect via mcp.honeycomb.io/mcp (no token needed here)

# Home Assistant
HOMEASSISTANT_URL=http://homeassistant.local:8123
HOMEASSISTANT_TOKEN=
